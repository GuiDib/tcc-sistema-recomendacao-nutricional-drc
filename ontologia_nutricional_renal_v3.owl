<owl:Class rdf:about="#EstagioG1">
  <rdfs:subClassOf rdf:resource="#EstagioDRC"/>
  <rdfs:comment xml:lang="pt">TFG &gt;= 90 mL/min/1.73m2</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#EstagioG2">
  <rdfs:subClassOf rdf:resource="#EstagioDRC"/>
  <rdfs:comment xml:lang="pt">TFG 60-89 mL/min/1.73m2</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#EstagioG3a">
  <rdfs:subClassOf rdf:resource="#EstagioDRC"/>
  <rdfs:comment xml:lang="pt">TFG 45-59 mL/min/1.73m2</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#EstagioG3b">
  <rdfs:subClassOf rdf:resource="#EstagioDRC"/>
  <rdfs:comment xml:lang="pt">TFG 30-44 mL/min/1.73m2</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#EstagioG4">
  <rdfs:subClassOf rdf:resource="#EstagioDRC"/>
  <rdfs:comment xml:lang="pt">TFG 15-29 mL/min/1.73m2</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#EstagioG5">
  <rdfs:subClassOf rdf:resource="#EstagioDRC"/>
