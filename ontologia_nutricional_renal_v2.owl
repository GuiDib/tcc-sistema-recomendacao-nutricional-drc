<?xml version="1.0"?>
<Ontology xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://www.semanticweb.org/ontologia-nutricional-renal"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     ontologyIRI="http://www.semanticweb.org/ontologia-nutricional-renal">

    <Prefix name="" IRI="http://www.semanticweb.org/ontologia-nutricional-renal#"/>
    <Prefix name="owl" IRI="http://www.w3.org/2002/07/owl#"/>
    <Prefix name="rdf" IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#"/>
    <Prefix name="xml" IRI="http://www.w3.org/XML/1998/namespace"/>
    <Prefix name="xsd" IRI="http://www.w3.org/2001/XMLSchema#"/>
    <Prefix name="rdfs" IRI="http://www.w3.org/2000/01/rdf-schema#"/>

    <Annotation>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <Literal xml:lang="pt">OntoDRC — Ontologia Nutricional para Pacientes com Doença Renal Crônica. TCC de Guilherme Bessa — UnB/FCTE. 25 alimentos da tabela TACO com dados de potássio, sódio, fósforo, proteína e calorias por 100g. Restrições por estágio conforme KDIGO/KDOQI.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <Literal xml:lang="pt">OntoDRC — Ontologia Nutricional Renal v2</Literal>
    </Annotation>

    <!-- ============================================================ -->
    <!-- CLASSES                                                        -->
    <!-- ============================================================ -->

    <Declaration><Class IRI="#Alimento"/></Declaration>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Alimento</IRI>
        <Literal xml:lang="pt">Item alimentar que pode ser recomendado, restrito ou proibido para o paciente renal.</Literal>
    </AnnotationAssertion>

    <!-- Subclasses por Categoria -->
    <Declaration><Class IRI="#Fruta"/></Declaration>
    <SubClassOf><Class IRI="#Fruta"/><Class IRI="#Alimento"/></SubClassOf>
    <Declaration><Class IRI="#Verdura"/></Declaration>
    <SubClassOf><Class IRI="#Verdura"/><Class IRI="#Alimento"/></SubClassOf>
    <Declaration><Class IRI="#Leguminosa"/></Declaration>
    <SubClassOf><Class IRI="#Leguminosa"/><Class IRI="#Alimento"/></SubClassOf>
    <Declaration><Class IRI="#Cereal"/></Declaration>
    <SubClassOf><Class IRI="#Cereal"/><Class IRI="#Alimento"/></SubClassOf>
    <Declaration><Class IRI="#Proteina"/></Declaration>
    <SubClassOf><Class IRI="#Proteina"/><Class IRI="#Alimento"/></SubClassOf>
    <Declaration><Class IRI="#Laticinio"/></Declaration>
    <SubClassOf><Class IRI="#Laticinio"/><Class IRI="#Alimento"/></SubClassOf>
    <Declaration><Class IRI="#Bebida"/></Declaration>
    <SubClassOf><Class IRI="#Bebida"/><Class IRI="#Alimento"/></SubClassOf>
    <Declaration><Class IRI="#Industrializado"/></Declaration>
    <SubClassOf><Class IRI="#Industrializado"/><Class IRI="#Alimento"/></SubClassOf>
    <Declaration><Class IRI="#Tuberculo"/></Declaration>
    <SubClassOf><Class IRI="#Tuberculo"/><Class IRI="#Alimento"/></SubClassOf>
    <Declaration><Class IRI="#Ovo"/></Declaration>
    <SubClassOf><Class IRI="#Ovo"/><Class IRI="#Alimento"/></SubClassOf>

    <!-- Subclasses por Classificação Renal -->
    <Declaration><Class IRI="#AlimentoPermitido"/></Declaration>
    <SubClassOf><Class IRI="#AlimentoPermitido"/><Class IRI="#Alimento"/></SubClassOf>
    <Declaration><Class IRI="#AlimentoRestrito"/></Declaration>
    <SubClassOf><Class IRI="#AlimentoRestrito"/><Class IRI="#Alimento"/></SubClassOf>
    <Declaration><Class IRI="#AlimentoProibido"/></Declaration>
    <SubClassOf><Class IRI="#AlimentoProibido"/><Class IRI="#Alimento"/></SubClassOf>

    <!-- Nutriente -->
    <Declaration><Class IRI="#Nutriente"/></Declaration>
    <Declaration><Class IRI="#Macronutriente"/></Declaration>
    <SubClassOf><Class IRI="#Macronutriente"/><Class IRI="#Nutriente"/></SubClassOf>
    <Declaration><Class IRI="#Micronutriente"/></Declaration>
    <SubClassOf><Class IRI="#Micronutriente"/><Class IRI="#Nutriente"/></SubClassOf>
    <Declaration><Class IRI="#Eletrolito"/></Declaration>
    <SubClassOf><Class IRI="#Eletrolito"/><Class IRI="#Nutriente"/></SubClassOf>

    <!-- Paciente -->
    <Declaration><Class IRI="#Paciente"/></Declaration>

    <!-- EstágioDRC -->
    <Declaration><Class IRI="#EstagioDRC"/></Declaration>
    <Declaration><Class IRI="#EstagioG1"/></Declaration>
    <SubClassOf><Class IRI="#EstagioG1"/><Class IRI="#EstagioDRC"/></SubClassOf>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#EstagioG1</IRI><Literal xml:lang="pt">TFG >= 90 mL/min/1.73m2</Literal></AnnotationAssertion>
    <Declaration><Class IRI="#EstagioG2"/></Declaration>
    <SubClassOf><Class IRI="#EstagioG2"/><Class IRI="#EstagioDRC"/></SubClassOf>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#EstagioG2</IRI><Literal xml:lang="pt">TFG 60-89 mL/min/1.73m2</Literal></AnnotationAssertion>
    <Declaration><Class IRI="#EstagioG3a"/></Declaration>
    <SubClassOf><Class IRI="#EstagioG3a"/><Class IRI="#EstagioDRC"/></SubClassOf>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#EstagioG3a</IRI><Literal xml:lang="pt">TFG 45-59 mL/min/1.73m2</Literal></AnnotationAssertion>
    <Declaration><Class IRI="#EstagioG3b"/></Declaration>
    <SubClassOf><Class IRI="#EstagioG3b"/><Class IRI="#EstagioDRC"/></SubClassOf>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#EstagioG3b</IRI><Literal xml:lang="pt">TFG 30-44 mL/min/1.73m2</Literal></AnnotationAssertion>
    <Declaration><Class IRI="#EstagioG4"/></Declaration>
    <SubClassOf><Class IRI="#EstagioG4"/><Class IRI="#EstagioDRC"/></SubClassOf>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#EstagioG4</IRI><Literal xml:lang="pt">TFG 15-29 mL/min/1.73m2</Literal></AnnotationAssertion>
    <Declaration><Class IRI="#EstagioG5"/></Declaration>
    <SubClassOf><Class IRI="#EstagioG5"/><Class IRI="#EstagioDRC"/></SubClassOf>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#EstagioG5</IRI><Literal xml:lang="pt">TFG &lt; 15 mL/min/1.73m2. Inclui pacientes em diálise.</Literal></AnnotationAssertion>

    <!-- RestriçãoNutricional -->
    <Declaration><Class IRI="#RestricaoNutricional"/></Declaration>
    <Declaration><Class IRI="#RestricaoPotassio"/></Declaration>
    <SubClassOf><Class IRI="#RestricaoPotassio"/><Class IRI="#RestricaoNutricional"/></SubClassOf>
    <Declaration><Class IRI="#RestricaoSodio"/></Declaration>
    <SubClassOf><Class IRI="#RestricaoSodio"/><Class IRI="#RestricaoNutricional"/></SubClassOf>
    <Declaration><Class IRI="#RestricaoFosforo"/></Declaration>
    <SubClassOf><Class IRI="#RestricaoFosforo"/><Class IRI="#RestricaoNutricional"/></SubClassOf>
    <Declaration><Class IRI="#RestricaoProteina"/></Declaration>
    <SubClassOf><Class IRI="#RestricaoProteina"/><Class IRI="#RestricaoNutricional"/></SubClassOf>
    <Declaration><Class IRI="#RestricaoLiquido"/></Declaration>
    <SubClassOf><Class IRI="#RestricaoLiquido"/><Class IRI="#RestricaoNutricional"/></SubClassOf>

    <!-- RecomendaçãoDietética -->
    <Declaration><Class IRI="#RecomendacaoDietetica"/></Declaration>

    <!-- RiscoClínico -->
    <Declaration><Class IRI="#RiscoClinico"/></Declaration>
    <Declaration><Class IRI="#Hipercalemia"/></Declaration>
    <SubClassOf><Class IRI="#Hipercalemia"/><Class IRI="#RiscoClinico"/></SubClassOf>
    <Declaration><Class IRI="#Hiperfosfatemia"/></Declaration>
    <SubClassOf><Class IRI="#Hiperfosfatemia"/><Class IRI="#RiscoClinico"/></SubClassOf>
    <Declaration><Class IRI="#Hipernatremia"/></Declaration>
    <SubClassOf><Class IRI="#Hipernatremia"/><Class IRI="#RiscoClinico"/></SubClassOf>
    <Declaration><Class IRI="#SobrecargaHidrica"/></Declaration>
    <SubClassOf><Class IRI="#SobrecargaHidrica"/><Class IRI="#RiscoClinico"/></SubClassOf>
    <Declaration><Class IRI="#DesnutricaoProteicoEnergetica"/></Declaration>
    <SubClassOf><Class IRI="#DesnutricaoProteicoEnergetica"/><Class IRI="#RiscoClinico"/></SubClassOf>

    <!-- ============================================================ -->
    <!-- OBJECT PROPERTIES                                             -->
    <!-- ============================================================ -->

    <Declaration><ObjectProperty IRI="#contemNutriente"/></Declaration>
    <ObjectPropertyDomain><ObjectProperty IRI="#contemNutriente"/><Class IRI="#Alimento"/></ObjectPropertyDomain>
    <ObjectPropertyRange><ObjectProperty IRI="#contemNutriente"/><Class IRI="#Nutriente"/></ObjectPropertyRange>

    <Declaration><ObjectProperty IRI="#possuiEstagio"/></Declaration>
    <FunctionalObjectProperty><ObjectProperty IRI="#possuiEstagio"/></FunctionalObjectProperty>
    <ObjectPropertyDomain><ObjectProperty IRI="#possuiEstagio"/><Class IRI="#Paciente"/></ObjectPropertyDomain>
    <ObjectPropertyRange><ObjectProperty IRI="#possuiEstagio"/><Class IRI="#EstagioDRC"/></ObjectPropertyRange>

    <Declaration><ObjectProperty IRI="#temRestricao"/></Declaration>
    <ObjectPropertyDomain><ObjectProperty IRI="#temRestricao"/><Class IRI="#EstagioDRC"/></ObjectPropertyDomain>
    <ObjectPropertyRange><ObjectProperty IRI="#temRestricao"/><Class IRI="#RestricaoNutricional"/></ObjectPropertyRange>

    <Declaration><ObjectProperty IRI="#recomendaAlimento"/></Declaration>
    <ObjectPropertyDomain><ObjectProperty IRI="#recomendaAlimento"/><Class IRI="#RecomendacaoDietetica"/></ObjectPropertyDomain>
    <ObjectPropertyRange><ObjectProperty IRI="#recomendaAlimento"/><Class IRI="#Alimento"/></ObjectPropertyRange>

