    <ClassAssertion><Class IRI="#EstagioG4"/><NamedIndividual IRI="#G4"/></ClassAssertion>
    <Declaration><NamedIndividual IRI="#G5"/></Declaration>
    <ClassAssertion><Class IRI="#EstagioG5"/><NamedIndividual IRI="#G5"/></ClassAssertion>

    <!-- ============================================================ -->
    <!-- RESTRIÇÕES POR ESTÁGIO (KDIGO/KDOQI)                         -->
    <!-- ============================================================ -->

    <!-- G3a: sódio restrito -->
    <Declaration><NamedIndividual IRI="#RestSodioG3a"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoSodio"/><NamedIndividual IRI="#RestSodioG3a"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioMg"/><NamedIndividual IRI="#RestSodioG3a"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">2000.0</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G3a"/><NamedIndividual IRI="#RestSodioG3a"/></ObjectPropertyAssertion>

    <!-- G3b: potássio, sódio, fósforo, proteína -->
    <Declaration><NamedIndividual IRI="#RestPotassioG3b"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoPotassio"/><NamedIndividual IRI="#RestPotassioG3b"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioMg"/><NamedIndividual IRI="#RestPotassioG3b"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">2000.0</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G3b"/><NamedIndividual IRI="#RestPotassioG3b"/></ObjectPropertyAssertion>

    <Declaration><NamedIndividual IRI="#RestSodioG3b"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoSodio"/><NamedIndividual IRI="#RestSodioG3b"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioMg"/><NamedIndividual IRI="#RestSodioG3b"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">2000.0</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G3b"/><NamedIndividual IRI="#RestSodioG3b"/></ObjectPropertyAssertion>

    <Declaration><NamedIndividual IRI="#RestFosforoG3b"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoFosforo"/><NamedIndividual IRI="#RestFosforoG3b"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioMg"/><NamedIndividual IRI="#RestFosforoG3b"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">800.0</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G3b"/><NamedIndividual IRI="#RestFosforoG3b"/></ObjectPropertyAssertion>

    <Declaration><NamedIndividual IRI="#RestProteinaG3b"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoProteina"/><NamedIndividual IRI="#RestProteinaG3b"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioGkg"/><NamedIndividual IRI="#RestProteinaG3b"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">0.6</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G3b"/><NamedIndividual IRI="#RestProteinaG3b"/></ObjectPropertyAssertion>

    <!-- G4: mesmas restrições com limites mais rigorosos -->
    <Declaration><NamedIndividual IRI="#RestPotassioG4"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoPotassio"/><NamedIndividual IRI="#RestPotassioG4"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioMg"/><NamedIndividual IRI="#RestPotassioG4"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">1500.0</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G4"/><NamedIndividual IRI="#RestPotassioG4"/></ObjectPropertyAssertion>

    <Declaration><NamedIndividual IRI="#RestSodioG4"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoSodio"/><NamedIndividual IRI="#RestSodioG4"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioMg"/><NamedIndividual IRI="#RestSodioG4"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">2000.0</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G4"/><NamedIndividual IRI="#RestSodioG4"/></ObjectPropertyAssertion>

    <Declaration><NamedIndividual IRI="#RestFosforoG4"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoFosforo"/><NamedIndividual IRI="#RestFosforoG4"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioMg"/><NamedIndividual IRI="#RestFosforoG4"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">800.0</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G4"/><NamedIndividual IRI="#RestFosforoG4"/></ObjectPropertyAssertion>

    <Declaration><NamedIndividual IRI="#RestProteinaG4"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoProteina"/><NamedIndividual IRI="#RestProteinaG4"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioGkg"/><NamedIndividual IRI="#RestProteinaG4"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">0.6</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G4"/><NamedIndividual IRI="#RestProteinaG4"/></ObjectPropertyAssertion>

    <!-- G5 (diálise): proteína sobe, demais restritos + líquido -->
    <Declaration><NamedIndividual IRI="#RestPotassioG5"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoPotassio"/><NamedIndividual IRI="#RestPotassioG5"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioMg"/><NamedIndividual IRI="#RestPotassioG5"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">1500.0</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G5"/><NamedIndividual IRI="#RestPotassioG5"/></ObjectPropertyAssertion>

    <Declaration><NamedIndividual IRI="#RestSodioG5"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoSodio"/><NamedIndividual IRI="#RestSodioG5"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioMg"/><NamedIndividual IRI="#RestSodioG5"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">2000.0</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G5"/><NamedIndividual IRI="#RestSodioG5"/></ObjectPropertyAssertion>

    <Declaration><NamedIndividual IRI="#RestFosforoG5"/></Declaration>
    <ClassAssertion><Class IRI="#RestricaoFosforo"/><NamedIndividual IRI="#RestFosforoG5"/></ClassAssertion>
    <DataPropertyAssertion><DataProperty IRI="#limiteDiarioMg"/><NamedIndividual IRI="#RestFosforoG5"/><Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#double">800.0</Literal></DataPropertyAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#temRestricao"/><NamedIndividual IRI="#G5"/><NamedIndividual IRI="#RestFosforoG5"/></ObjectPropertyAssertion>

