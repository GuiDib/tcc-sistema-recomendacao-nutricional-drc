    <Declaration><NamedIndividual IRI="#G1"/></Declaration>
    <ClassAssertion><Class IRI="#EstagioG1"/><NamedIndividual IRI="#G1"/></ClassAssertion>
    <Declaration><NamedIndividual IRI="#G2"/></Declaration>
    <ClassAssertion><Class IRI="#EstagioG2"/><NamedIndividual IRI="#G2"/></ClassAssertion>
    <Declaration><NamedIndividual IRI="#G3a"/></Declaration>
    <ClassAssertion><Class IRI="#EstagioG3a"/><NamedIndividual IRI="#G3a"/></ClassAssertion>
