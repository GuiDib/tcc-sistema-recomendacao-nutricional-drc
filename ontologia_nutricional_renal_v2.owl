    <Declaration><NamedIndividual IRI="#Potassio"/></Declaration>
    <ClassAssertion><Class IRI="#Eletrolito"/><NamedIndividual IRI="#Potassio"/></ClassAssertion>
    <ObjectPropertyAssertion><ObjectProperty IRI="#provocaRisco"/><NamedIndividual IRI="#Potassio"/><NamedIndividual IRI="#RiscoHipercalemia"/></ObjectPropertyAssertion>

