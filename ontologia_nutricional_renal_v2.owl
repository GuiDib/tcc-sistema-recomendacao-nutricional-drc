    <Declaration><ObjectProperty IRI="#provocaRisco"/></Declaration>
    <ObjectPropertyDomain><ObjectProperty IRI="#provocaRisco"/><Class IRI="#Nutriente"/></ObjectPropertyDomain>
    <ObjectPropertyRange><ObjectProperty IRI="#provocaRisco"/><Class IRI="#RiscoClinico"/></ObjectPropertyRange>

    <Declaration><ObjectProperty IRI="#geradaPara"/></Declaration>
    <ObjectPropertyDomain><ObjectProperty IRI="#geradaPara"/><Class IRI="#RecomendacaoDietetica"/></ObjectPropertyDomain>
    <ObjectPropertyRange><ObjectProperty IRI="#geradaPara"/><Class IRI="#Paciente"/></ObjectPropertyRange>

    <Declaration><ObjectProperty IRI="#comBaseEm"/></Declaration>
    <ObjectPropertyDomain><ObjectProperty IRI="#comBaseEm"/><Class IRI="#RecomendacaoDietetica"/></ObjectPropertyDomain>
    <ObjectPropertyRange><ObjectProperty IRI="#comBaseEm"/><Class IRI="#RestricaoNutricional"/></ObjectPropertyRange>

    <!-- ============================================================ -->
